# Repo-Insight Configuration
# Copy this file to .env and fill in your values.
# Required: SGLANG_BASE_URL, SGLANG_API_KEY, LLM_MODEL

# Database connection host
FALKORDB_HOST="localhost"

# Database connection port
FALKORDB_PORT="6379"

# Graph database name
GRAPH_NAME="repo_insight"

# Inference server base URL
SGLANG_BASE_URL="http://localhost:30000/v1"

# Inference server API key
SGLANG_API_KEY="EMPTY"

# Main LLM model to use
LLM_MODEL="Qwen/Qwen3-8B"

# Local sentence-transformer model for embeddings
EMBEDDING_MODEL="all-MiniLM-L6-v2"

# Output dimension for the embedding model
EMBEDDING_DIM="384"

# Maximum graph depth for resolving downstream impact
IMPACT_RADIUS_MAX_DEPTH="3"

# Maximum graph depth for resolving upstream blast radius
BLAST_RADIUS_MAX_DEPTH="4"

# Warn threshold for wide impact radius size
IMPACT_RADIUS_WARN_THRESHOLD="5"

# Maximum ReAct agent iterations
AGENT_MAX_ITERATIONS="10"

# Maximum seconds to wait for a tool to execute
AGENT_TOOL_TIMEOUT_SECONDS="30"

# Whether to completely clear the graph on each ingestion
FLUSH_GRAPH_ON_INGEST="false"

# Maximum concurrency for LLM node summarization
INGEST_CONCURRENCY="5"

# Comma-separated list of directories to skip during graph ingestion
SKIP_DIRS="__pycache__,.git,.venv,venv,node_modules,dist,build"

# Test command used in sandbox during verification
TEST_COMMAND="pytest tests/ -v --tb=short -q -m 'not integration'"

# Maximum string length allowed for a tool's serialized JSON result
TOOL_OUTPUT_MAX_LENGTH="8000"
